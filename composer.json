{
    "name": "termon/ui",
    "description": "Set of Blade View Components",
    "type": "library",
    "version": "1.8.27",
    "autoload": {
        "psr-4": {
            "Termon\\Ui\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Termon\\Ui\\TermonUiServiceProvider"
            ]
        }
    },
    "authors": [
        {
            "name": "termon",
            "email": "a.mccaughey@ulster.ac.uk"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.5|^11.5|^12.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Termon\\Ui\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    }
}
